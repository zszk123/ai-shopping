# Runtime
PROJECT_NAME=AI Shopping Compare
ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=*

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=ai_shopping

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Milvus
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_COLLECTION=goods_vectors

# Security
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRE_HOURS=24
INTERNAL_API_TOKEN=change-me-to-a-long-internal-token
LOGIN_RATE_LIMIT_COUNT=10
LOGIN_RATE_LIMIT_SECONDS=60

# Alibaba Cloud DashScope
DASHSCOPE_API_KEY=sk-your-dashscope-api-key
VISION_MODEL=qwen-vl-plus
VISION_FALLBACK_MODELS=qwen3-vl-plus,qwen-vl-plus
EMBEDDING_MODEL=text-embedding-v3
VISION_EMBEDDING_MODEL=tongyi-embedding-vision-flash
RERANK_MODEL=qwen3-rerank
MATH_MODEL=qwen-math-turbo

# DeepSeek optional fallback
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-vl2

# Spider
SPIDER_AUTO_START=false

# Alibaba Cloud OSS
OSS_ACCESS_KEY=your-oss-access-key-id
OSS_SECRET_KEY=your-oss-access-key-secret
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET=your-bucket-name

# Performance
VECTOR_CACHE_TTL=300
GOODS_INFO_CACHE_TTL=600
COMPARE_RESULT_CACHE_TTL=600
AI_ANALYSIS_CACHE_TTL=1800
ENABLE_AI_PRICE_ANALYSIS=false
AI_PRICE_ANALYSIS_TIMEOUT_SECONDS=3
RERANK_TIMEOUT_SECONDS=5
JWT_CACHE_TTL=86400

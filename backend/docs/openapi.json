            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "UrlCompareReq": {
        "properties": {
          "goods_url": {
            "type": "string",
            "maxLength": 2083,
            "minLength": 1,
            "format": "uri",
            "title": "Goods Url",
            "description": "商品链接"
          },
          "token": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Token"
          }
        },
        "type": "object",
        "required": [
          "goods_url"
        ],
        "title": "UrlCompareReq"
      },
      "UserLoginReq": {
        "properties": {
          "phone": {
            "type": "string",
            "maxLength": 11,
            "minLength": 11,
            "pattern": "^\\d{11}$",
            "title": "Phone"
          },
          "password": {
            "type": "string",
            "maxLength": 64,
            "minLength": 6,
            "title": "Password"
          }
        },
        "type": "object",
        "required": [
          "phone",
          "password"
        ],
        "title": "UserLoginReq"
      },
      "UserRegisterReq": {
        "properties": {
          "username": {
            "type": "string",
            "maxLength": 32,
            "minLength": 1,
            "title": "Username"
          },
          "password": {
            "type": "string",
            "maxLength": 64,
            "minLength": 6,
            "title": "Password"
          },
          "phone": {
            "type": "string",
            "maxLength": 11,
            "minLength": 11,
            "pattern": "^\\d{11}$",
            "title": "Phone"
          }
        },
        "type": "object",
        "required": [
          "username",
          "password",
          "phone"
        ],
        "title": "UserRegisterReq"
      },
      "UserUpdateReq": {
        "properties": {
          "username": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 32
              },
              {
                "type": "null"
              }
            ],
            "title": "Username"
          },
          "avatar": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 512
              },
              {
                "type": "null"
              }
            ],
            "title": "Avatar"
          }
        },
        "type": "object",
        "title": "UserUpdateReq"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }

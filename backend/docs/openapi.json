  "components": {
    "schemas": {
      "Body_compare_by_image_api_compare_image_post": {
        "properties": {
          "file": {
            "type": "string",
            "format": "binary",
            "title": "File"
          }
        },
        "type": "object",
        "required": [
          "file"
        ],
        "title": "Body_compare_by_image_api_compare_image_post"
